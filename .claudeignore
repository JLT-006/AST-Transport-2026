# 🛑 AI Agent Ignore File - Prevents context bloat and saves input tokens

# 1. Lockfiles (Massive JSON/YAML files that AI doesn't need to read)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# 2. Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# 3. Build & Output (Minified/Compiled code is useless for AI reasoning)
dist/
out/
build/
.next/
coverage/

# 4. Large Media & Static Assets (Binary or heavy SVG files)
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp4
*.webm
*.ico
*.svg
*.pdf
*.zip
*.tar.gz

# 5. Database Dumps & Logs
*.sql
*.sqlite
*.sqlite3
*.log
npm-debug.log*

# 6. Environment & Secrets (Security & noise prevention)
.env*
!.env.example
